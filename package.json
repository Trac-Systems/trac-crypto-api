{
  "name": "trac-crypto-api",
  "version": "0.1.5",
  "main": "index.js",
  "exports": {
    ".": {
      "react-native": "./dist/trac-crypto-api.rn.js",
      "browser": "./dist/trac-crypto-api.browser.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "modules/",
    "constants.js",
    "dist/*.js",
    "dist/*.txt"
  ],
  "pear": {
    "name": "trac-crypto-api",
    "type": "terminal"
  },
  "scripts": {
    "build:all": "npm run build:browser && npm run build:rn",
    "build:browser": "rollup -c && npm run setup:browser",
    "setup:browser": "rm -rf test/browser/node_modules/trac-crypto-api && rm -f test/browser/*.tgz && npm run pack:test && cd test/browser && npm install ./trac-crypto-api-*.tgz",
    "build:rn": "npm run setup:rn && webpack --config webpack.config.rn.js && npm run cleanup:rn",
    "setup:rn": "npm install crypto-browserify stream-browserify vm-browserify buffer url assert --no-save --cache ./.npm-cache",
    "cleanup:rn": "npm uninstall crypto-browserify stream-browserify vm-browserify buffer url assert --no-save",
    "test:node": "brittle-node -t 120000 test/unit/all.test.js",
    "test:bare": "brittle-bare -t 120000 test/unit/all.test.js",
    "test:browser": "rm -rf test/browser/node_modules/trac-crypto-api && rm -f test/browser/*.tgz && npm run pack:test && cd test/browser && npm install ./trac-crypto-api-*.tgz && npm run test:browser",
    "test:all": "npm run test:node && npm run test:browser",
    "coverage": "c8 --all --include=constants.js --include=index.js --include=modules/**/*.js --exclude=test/** --exclude=dist/** --exclude=scripts/** --reporter=text --reporter=json-summary --reporter=lcov --reporter=html npm run test:node",
    "ci:clean": "node scripts/ci/clean.cjs && npm ci --cache ./.npm-cache",
    "ci:full": "npm run ci:clean && npm run test:node && npm run test:bare && npm run build:browser && npm run test:browser && npm run build:rn",
    "pack:test": "npm pack --pack-destination test/browser"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "util": {
      "bare": "bare-utils",
      "default": "util"
    },
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    }
  },
  "dependencies": {
    "@metamask/key-tree": "10.1.1",
    "@tracsystems/blake3": "0.0.15",
    "b4a": "1.6.7",
    "bare-fs": "4.5.0",
    "bech32": "2.0.0",
    "bip39-mnemonic": "2.5.0",
    "sodium-javascript": "0.8.0",
    "sodium-universal": "5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-classes": "^7.28.4",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^6.0.2",
    "babel-loader": "^10.0.0",
    "brittle": "^3.18.0",
    "c8": "^11.0.0",
    "ignore-loader": "^0.1.2",
    "rollup": "^4.50.2",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Trac-Systems/trac-crypto-api"
  }
}
